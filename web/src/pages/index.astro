  <main id="main">

    <!-- ── Hero ── -->
    <section class="hero">
      <div class="wrap hero-grid">

        <div>
          <span class="eyebrow">iOS Beta · Open Now</span>
          <h1>Control your coding agents <em>from anywhere.</em></h1>
          <p class="lede">
            Sidemesh runs beside your coding agents on the machines you trust,
            then gives you the remote surface around them: sessions, approvals,
            files, terminals, ports, and previews from your phone or desktop.
          </p>
          <div class="hero-actions">
            <a
              class="btn btn-primary"
              href="https://testflight.apple.com/join/UZ6FTc9r"
              target="_blank"
              rel="noreferrer"
            >
              Join iOS Beta
            </a>
            <a
              class="btn btn-secondary"
              href="https://discord.gg/URvvnN7Dv"
              target="_blank"
              rel="noreferrer"
            >
              Join Discord
