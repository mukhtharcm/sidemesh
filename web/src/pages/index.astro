---
// Landing page — custom layout, not Starlight
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Sidemesh — Your agent workstation, from anywhere</title>
<meta name="description" content="Run coding agents on your own Mac, VPS, or workstation. Control sessions, approvals, files, terminals, port forwarding, and browser previews from your phone or desktop." />
<meta name="theme-color" content="#0d0f14" />
<meta property="og:title" content="Sidemesh — Your agent workstation, from anywhere" />
<meta property="og:description" content="Sidemesh pairs a small daemon on your own machines with an iOS app for sessions, approvals, files, terminals, ports, and browser previews." />
<meta property="og:type" content="website" />
<meta property="og:image" content="/assets/og-card-v1.png" />
<meta property="og:image:alt" content="Sidemesh — agent workstation control from anywhere." />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content="/assets/og-card-v1.png" />
<meta name="twitter:image:alt" content="Sidemesh — agent workstation control from anywhere." />
<link rel="icon" type="image/png" href="/assets/favicon.png" />
<link rel="apple-touch-icon" href="/assets/app-icon.png" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
<style>
  /* ── Design tokens ── */
  :root {
    --bg:             #0d0f14;
    --bg-2:           #131519;
    --bg-3:           #191c23;
    --border:         rgba(255, 255, 255, 0.08);
    --border-strong:  rgba(255, 255, 255, 0.14);
    --text:           #ece9e3;
    --text-2:         #8b8e9c;
    --text-3:         #4d5060;
    --accent:         #f97316;
    --accent-dim:     rgba(249, 115, 22, 0.12);
    --green:          #34d399;
    --green-dim:      rgba(52, 211, 153, 0.08);
    --terminal-bg:    #07090d;
    --ease:           cubic-bezier(0.16, 1, 0.3, 1);
    --wrap:           min(1100px, calc(100% - 48px));
    --r:              16px;
  }

  /* ── Reset ── */
  *, *::before, *::after { box-sizing: border-box; }

  html {
    scroll-behavior: smooth;
    text-size-adjust: 100%;
  }

  body {
    margin: 0;
    overflow-x: hidden;
    color: var(--text);
    background-color: var(--bg);
    background-image:
      radial-gradient(ellipse 80% 50% at 12% -8%, rgba(249, 115, 22, 0.07), transparent),
      radial-gradient(ellipse 60% 40% at 88% 14%, rgba(52, 211, 153, 0.04), transparent);
    font-family: "Manrope", sans-serif;
    font-size: 16px;
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
  }

  ::selection {
    background: rgba(249, 115, 22, 0.2);
  }

  a { color: inherit; text-decoration: none; }
  p, li { text-wrap: pretty; margin: 0; }
  code { font-family: "Geist Mono", monospace; }

  .wrap {
    width: var(--wrap);
    margin: 0 auto;
  }

  /* ── Skip link ── */
  .skip-link {
    position: fixed;
    top: 12px;
    left: 12px;
    z-index: 40;
    padding: 8px 14px;
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    background: var(--bg-2);
    font-family: "Geist Mono", monospace;
    font-size: 12px;
    transform: translateY(-200%);
    transition: transform 180ms var(--ease);
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  /* ── Nav ── */
  .nav {
    position: sticky;
    top: 0;
    z-index: 20;
    border-bottom: 1px solid var(--border);
    background: rgba(13, 15, 20, 0.88);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    gap: 6px;
    min-height: 70px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 800;
    letter-spacing: -0.04em;
    flex-shrink: 0;
    margin-right: auto;
  }

  .brand-logo {
    width: 30px;
    height: 30px;
    border-radius: 9px;
    box-shadow: 0 0 0 1px var(--border-strong);
    display: block;
  }

  .nav-links {
    display: flex;
    flex-wrap: nowrap;
    gap: 2px;
    font-family: "Geist Mono", monospace;
    font-size: 12px;
    color: var(--text-2);
  }

  .nav-links a {
    padding: 8px 11px;
    border-radius: 8px;
    white-space: nowrap;
    transition: color 150ms, background 150ms;
  }

  .nav-links a:hover,
  .nav-links a:focus-visible {
    color: var(--text);
    background: rgba(255, 255, 255, 0.05);
  }

  .nav-cta {
    margin-left: 10px;
    flex-shrink: 0;
  }

  /* ── Buttons ── */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    min-height: 42px;
    padding: 10px 18px;
    border-radius: 10px;
    border: 1px solid transparent;
    font-family: "Geist Mono", monospace;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition:
      transform 200ms var(--ease),
      background 200ms var(--ease),
      border-color 200ms var(--ease),
      box-shadow 200ms var(--ease);
  }

  .btn-primary {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
    box-shadow: 0 0 0 0 rgba(249, 115, 22, 0.3);
  }

  .btn-primary:hover,
  .btn-primary:focus-visible {
    background: #ea6d10;
    border-color: #ea6d10;
    box-shadow: 0 0 0 4px rgba(249, 115, 22, 0.16);
    transform: translateY(-1px);
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.05);
    border-color: var(--border-strong);
    color: var(--text);
  }

  .btn-secondary:hover,
  .btn-secondary:focus-visible {
    background: rgba(255, 255, 255, 0.09);
    transform: translateY(-1px);
  }

  .btn-ghost {
    background: transparent;
    border-color: transparent;
    color: var(--text-2);
    padding-left: 4px;
    padding-right: 4px;
  }

  .btn-ghost:hover,
  .btn-ghost:focus-visible {
    color: var(--text);
    background: transparent;
  }

  .btn-ghost::after {
    content: " →";
    opacity: 0.6;
  }

  .btn:active {
    transform: translateY(1px) scale(0.99);
  }

  /* ── Eyebrow label ── */
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    color: var(--accent);
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .eyebrow::before {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-dim);
    content: "";
    flex-shrink: 0;
  }

  /* ── Hero ── */
  .hero {
    padding: 88px 0 72px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(420px, 0.8fr);
    gap: 56px;
    align-items: center;
  }

  .hero h1 {
    margin: 20px 0 16px;
    font-family: "Instrument Serif", serif;
    font-size: clamp(3rem, 6vw, 5.5rem);
    font-weight: 400;
    line-height: 0.94;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .hero h1 em {
    font-style: italic;
    color: var(--accent);
  }

  .hero .lede {
    max-width: 32rem;
    color: var(--text-2);
    font-size: 1.05rem;
    line-height: 1.68;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 28px;
  }

  .hero-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 26px;
    padding-top: 22px;
    border-top: 1px solid var(--border);
  }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 6px 12px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.03);
    color: var(--text-2);
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    font-weight: 500;
  }

  .pill::before {
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 0 3px var(--green-dim);
    content: "";
    flex-shrink: 0;
  }

  /* ── Terminal block ── */
  .terminal {
    border-radius: 18px;
    border: 1px solid var(--border-strong);
    background: var(--terminal-bg);
    overflow: hidden;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.03),
      0 32px 80px rgba(0, 0, 0, 0.55),
      0 8px 24px rgba(0, 0, 0, 0.3);
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 13px 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .terminal-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .terminal-dot:nth-child(1) { background: #ff5f57; }
  .terminal-dot:nth-child(2) { background: #febc2e; }
  .terminal-dot:nth-child(3) { background: #28c840; }

  .terminal-title {
    margin-left: 6px;
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    color: var(--text-3);
    letter-spacing: 0.02em;
  }

  .terminal-body {
    padding: 22px;
    font-family: "Geist Mono", monospace;
    font-size: 13px;
    line-height: 2;
    color: rgba(255, 255, 255, 0.72);
  }

  .t-dim   { color: var(--text-3); }
  .t-cmt   { color: #4d5870; }
  .t-prompt { color: var(--accent); font-weight: 600; }
  .t-cmd   { color: var(--text); }
  .t-ok    { color: var(--green); }
  .t-val   { color: #93c5fd; }
  .t-gap   { display: block; height: 4px; }

  /* ── Section base ── */
  .section {
    padding: 108px 0;
    border-top: 1px solid var(--border);
  }

  .section-lead {
    margin-bottom: 48px;
  }

  .section-lead h2 {
    margin: 14px 0 14px;
    font-family: "Instrument Serif", serif;
    font-size: clamp(2.4rem, 4vw, 3.8rem);
    font-weight: 400;
    line-height: 0.96;
    letter-spacing: -0.04em;
    text-wrap: balance;
    max-width: 15ch;
  }

  .section-lead p {
    max-width: 36rem;
    color: var(--text-2);
    font-size: 1.02rem;
    line-height: 1.68;
  }

  /* ── Feature grid ── */
  /* gap:1px + bg = visible 1px grid lines */
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--r);
    overflow: hidden;
  }

  .feature-card {
    padding: 28px 24px;
    background: var(--bg-2);
    transition: background 200ms;
  }

  .feature-card:hover {
    background: var(--bg-3);
  }

  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 10px;
    background: var(--accent-dim);
    border: 1px solid rgba(249, 115, 22, 0.18);
    margin-bottom: 18px;
    color: var(--accent);
    flex-shrink: 0;
  }

  .feature-card h3 {
    margin: 0 0 9px;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.3;
  }

  .feature-card p {
    color: var(--text-2);
    font-size: 0.91rem;
    line-height: 1.65;
  }

  /* ── How it works: steps ── */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 40px;
  }

  .step {
    padding-top: 22px;
    border-top: 2px solid var(--border);
    position: relative;
  }

  .step-num {
    display: block;
    margin-bottom: 14px;
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .step h3 {
    margin: 0 0 10px;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.3;
  }

  .step p {
    color: var(--text-2);
    font-size: 0.91rem;
    line-height: 1.65;
  }

  /* ── CSS-only product visuals ── */
  .mesh-panel {
    position: relative;
    min-height: 520px;
    overflow: hidden;
    border: 1px solid var(--border-strong);
    border-radius: 30px;
    background:
      radial-gradient(circle at 78% 28%, rgba(249, 115, 22, 0.14), transparent 18rem),
      radial-gradient(circle at 18% 72%, rgba(52, 211, 153, 0.12), transparent 17rem),
      linear-gradient(135deg, #10131a 0%, #090b10 62%, #11151d 100%);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.03),
      0 38px 100px rgba(0, 0, 0, 0.55);
    isolation: isolate;
  }

  .mesh-panel::before {
    position: absolute;
    inset: 0;
    z-index: -2;
    content: "";
    opacity: 0.28;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.045) 1px, transparent 1px),
      radial-gradient(circle, rgba(255, 255, 255, 0.18) 1px, transparent 1.6px);
    background-size: 96px 96px, 96px 96px, 22px 22px;
    mask-image: linear-gradient(140deg, black 0%, rgba(0, 0, 0, 0.72) 56%, transparent 100%);
  }

  .mesh-panel::after {
    position: absolute;
    inset: auto -10% -28% -10%;
    z-index: -1;
    height: 42%;
    content: "";
    background: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.58), transparent 68%);
  }

  .mesh-route {
    position: absolute;
    border: 1px dashed rgba(52, 211, 153, 0.34);
    border-right: 0;
    border-bottom: 0;
    border-radius: 26px 0 0 0;
  }

  .mesh-route.orange {
    border-color: rgba(249, 115, 22, 0.34);
    border-left: 0;
    border-right: 1px dashed rgba(249, 115, 22, 0.34);
    border-radius: 0 26px 0 0;
  }

  .route-a { left: 12%; top: 26%; width: 35%; height: 38%; }
  .route-b { right: 9%; top: 32%; width: 30%; height: 34%; }

  .mesh-node {
    position: absolute;
    display: grid;
    justify-items: center;
    gap: 7px;
    color: var(--text-3);
    font-family: "Geist Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.02em;
    text-align: center;
  }

  .mesh-node i {
    display: grid;
    place-items: center;
    width: 54px;
    height: 54px;
    border: 1px solid rgba(52, 211, 153, 0.38);
    border-radius: 999px;
    background: rgba(52, 211, 153, 0.06);
    color: var(--green);
    box-shadow: 0 0 0 18px rgba(52, 211, 153, 0.035);
    font-style: normal;
  }

  .mesh-node.orange i {
    border-color: rgba(249, 115, 22, 0.42);
    background: rgba(249, 115, 22, 0.07);
    color: var(--accent);
    box-shadow: 0 0 0 18px rgba(249, 115, 22, 0.035);
  }

  .node-phone { left: 8%; top: 38%; }
  .node-host { left: 23%; top: 12%; }
  .node-agent { left: 24%; bottom: 15%; }
  .node-work { right: 10%; top: 39%; }

  .device-stack {
    position: absolute;
    inset: 0;
  }

  .mini-phone {
    position: absolute;
    width: 236px;
    min-height: 398px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 35px;
    background: linear-gradient(180deg, #171b24, #090b10);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.05),
      0 28px 70px rgba(0, 0, 0, 0.7);
  }

  .phone-front {
    left: 28%;
    bottom: -34px;
    z-index: 3;
    transform: rotate(-3deg);
  }

  .phone-back {
    right: 12%;
    bottom: 22px;
    z-index: 2;
    opacity: 0.9;
    transform: rotate(4deg);
  }

  .phone-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 18px 18px 10px;
    color: rgba(255, 255, 255, 0.82);
    font-family: "Geist Mono", monospace;
    font-size: 10px;
  }

  .phone-pill {
    width: 66px;
    height: 21px;
    border-radius: 999px;
    background: #020305;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.05);
  }

  .phone-title {
    padding: 4px 18px 14px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }

  .phone-title strong {
    display: block;
    margin-bottom: 2px;
    font-size: 14px;
    letter-spacing: -0.03em;
  }

  .phone-title span {
    color: var(--text-3);
    font-family: "Geist Mono", monospace;
    font-size: 10px;
  }

  .phone-body {
    padding: 14px 16px 20px;
  }

  .action-row,
  .file-row,
  .session-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 10px;
    align-items: center;
    padding: 11px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }

  .action-row:last-child,
  .file-row:last-child,
  .session-row:last-child { border-bottom: 0; }

  .row-icon {
    display: grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border-radius: 9px;
    background: rgba(255, 255, 255, 0.06);
    color: #9fc7d6;
    font-family: "Geist Mono", monospace;
    font-size: 12px;
  }

  .row-copy strong {
    display: block;
    font-size: 12px;
    line-height: 1.2;
  }

  .row-copy span {
    color: var(--text-3);
    font-size: 10px;
  }

  .file-row {
    grid-template-columns: auto 1fr auto;
    font-family: "Geist Mono", monospace;
    font-size: 11px;
  }

  .file-row b {
    color: #9fc7d6;
    font-weight: 600;
  }

  .file-row small {
    color: var(--text-3);
  }

  .surface-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .surface-card {
    min-height: 250px;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 22px;
    background:
      radial-gradient(circle at 24% 12%, rgba(249, 115, 22, 0.13), transparent 14rem),
      linear-gradient(180deg, #11151d, #090b10);
  }

  .surface-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 13px 15px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    color: var(--text-3);
    font-family: "Geist Mono", monospace;
    font-size: 10px;
  }

  .surface-body {
    padding: 15px;
    font-family: "Geist Mono", monospace;
    font-size: 12px;
    line-height: 1.8;
  }

  .surface-body .green { color: #a7d38f; }
  .surface-body .blue { color: #9fc7d6; }
  .surface-body .orange { color: #e7b06d; }
  .surface-body .dim { color: var(--text-3); }

  .surface-list {
    display: grid;
    gap: 9px;
    padding: 15px;
  }

  .surface-list span {
    display: flex;
    align-items: center;
    gap: 9px;
    color: rgba(236, 233, 227, 0.84);
    font-family: "Geist Mono", monospace;
    font-size: 12px;
  }

  .surface-list span::before {
    width: 8px;
    height: 8px;
    border-radius: 2px;
    background: #9fc7d6;
    content: "";
  }

  .showcase-list {
    display: grid;
    gap: 24px;
  }

  .showcase-row {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.75fr);
    gap: 32px;
    align-items: center;
    padding: 26px;
    border: 1px solid var(--border);
    border-radius: 30px;
    background: rgba(255, 255, 255, 0.025);
  }

  .showcase-row.reverse {
    grid-template-columns: minmax(280px, 0.75fr) minmax(0, 1.05fr);
  }

  .showcase-copy h3 {
    margin: 10px 0 12px;
    font-size: clamp(1.7rem, 3vw, 2.6rem);
    line-height: 1;
    letter-spacing: -0.055em;
    text-wrap: balance;
  }

  .showcase-copy p {
    color: var(--text-2);
    line-height: 1.7;
  }

  /* ── Install section ── */
  .install-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--r);
    overflow: hidden;
  }

  .install-card {
    padding: 28px 24px;
    background: var(--bg-2);
    display: flex;
    flex-direction: column;
  }

  .install-num {
    display: block;
    margin-bottom: 14px;
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .install-card h3 {
    margin: 0 0 10px;
    font-size: 1.18rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.25;
  }

  .install-card > p {
    color: var(--text-2);
    font-size: 0.91rem;
    line-height: 1.65;
    flex: 1;
  }

  .code-block {
    margin-top: 18px;
    padding: 16px 18px;
    border-radius: 12px;
    background: var(--terminal-bg);
    border: 1px solid var(--border);
    font-family: "Geist Mono", monospace;
    font-size: 12.5px;
    line-height: 2;
    color: rgba(255, 255, 255, 0.72);
    overflow-x: auto;
  }

  .code-block .p { color: var(--accent); }

  .install-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 20px;
  }

  /* ── Security ── */
  .security-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 56px;
    align-items: start;
  }

  .security-copy h2 {
    margin: 14px 0 14px;
    font-family: "Instrument Serif", serif;
    font-size: clamp(2rem, 3.4vw, 3.2rem);
    font-weight: 400;
    line-height: 0.96;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .security-copy p {
    color: var(--text-2);
    font-size: 0.97rem;
    line-height: 1.7;
  }

  .security-copy p + p {
    margin-top: 12px;
  }

  .route-diagram {
    padding: 24px;
    border-radius: var(--r);
    border: 1px solid var(--border);
    background: var(--bg-2);
  }

  .route-label {
    display: block;
    margin-bottom: 18px;
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-3);
  }

  .route-item {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 10px;
    align-items: center;
    padding: 12px 0;
    border-top: 1px solid var(--border);
    font-family: "Geist Mono", monospace;
    font-size: 12px;
  }

  .route-item:first-of-type {
    border-top: none;
  }

  .route-from {
    color: var(--text-2);
  }

  .route-to {
    color: var(--text-2);
    text-align: right;
  }

  .route-via {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--green);
    white-space: nowrap;
    padding: 0 4px;
  }

  .route-via::before,
  .route-via::after {
    display: block;
    height: 1px;
    min-width: 14px;
    flex: 1;
    background: rgba(52, 211, 153, 0.2);
    content: "";
  }

  .route-note {
    margin-top: 18px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
    font-size: 0.83rem;
    color: var(--text-3);
    line-height: 1.6;
  }

  /* ── FAQ ── */
  .faq-list {
    display: grid;
    gap: 0;
    border-top: 1px solid var(--border);
  }

  .faq-item {
    display: grid;
    grid-template-columns: minmax(180px, 240px) minmax(0, 1fr);
    gap: 24px;
    padding: 20px 0;
    border-bottom: 1px solid var(--border);
  }

  .faq-item strong {
    display: block;
    font-size: 0.96rem;
    letter-spacing: -0.02em;
    color: var(--text);
    align-self: start;
    padding-top: 1px;
    line-height: 1.4;
  }

  .faq-item p {
    color: var(--text-2);
    font-size: 0.93rem;
    line-height: 1.68;
  }

  /* ── Closing CTA ── */
  .closing {
    padding: 100px 0;
    border-top: 1px solid var(--border);
  }

  .closing-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 40px;
    align-items: end;
    padding: 44px;
    border-radius: 22px;
    border: 1px solid var(--border-strong);
    background:
      radial-gradient(ellipse 70% 80% at 0% 60%, rgba(249, 115, 22, 0.08), transparent),
      var(--bg-2);
  }

  .closing-card h2 {
    margin: 0 0 12px;
    font-family: "Instrument Serif", serif;
    font-size: clamp(2rem, 3.6vw, 3.4rem);
    font-weight: 400;
    line-height: 0.96;
    letter-spacing: -0.04em;
    text-wrap: balance;
    max-width: 14ch;
  }

  .closing-card p {
    color: var(--text-2);
    font-size: 0.97rem;
    max-width: 34rem;
    line-height: 1.68;
  }

  .closing-actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: flex-end;
  }

  /* ── Footer ── */
  footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 24px 0 40px;
    border-top: 1px solid var(--border);
    font-family: "Geist Mono", monospace;
    font-size: 12px;
    color: var(--text-3);
  }

  footer nav {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  footer a {
    padding: 6px 10px;
    border-radius: 6px;
    color: var(--text-3);
    transition: color 150ms, background 150ms;
  }

  footer a:hover {
    color: var(--text);
    background: rgba(255, 255, 255, 0.04);
  }

  /* ── Focus ── */
  :focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: 4px;
  }

  /* ── Responsive ── */
  @media (max-width: 980px) {
    .mesh-panel {
      width: min(100%, 640px);
    }

    .hero-grid {
      grid-template-columns: 1fr;
    }

    .terminal {
      max-width: 480px;
    }

    .feature-grid,
    .steps-grid,
    .install-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .security-inner,
    .closing-card,
    .showcase-row,
    .showcase-row.reverse {
      grid-template-columns: 1fr;
    }

    .showcase-row.reverse .showcase-copy {
      order: -1;
    }

    .closing-actions {
      align-items: flex-start;
      flex-direction: row;
      flex-wrap: wrap;
    }

    .section {
      padding: 84px 0;
    }
  }

  @media (max-width: 680px) {
    .mesh-panel {
      display: none;
    }

    .surface-grid {
      grid-template-columns: 1fr;
    }

    .surface-card {
      min-height: auto;
    }

    .showcase-row {
      padding: 16px;
    }

    :root {
      --wrap: min(calc(100% - 32px), 1100px);
    }

    .nav-links {
      display: none;
    }

    .hero {
      padding: 52px 0 56px;
    }

    .hero h1 {
      font-size: clamp(2.8rem, 13vw, 3.8rem);
    }

    .hero-actions,
    .install-actions {
      flex-direction: column;
    }

    .btn-primary,
    .btn-secondary {
      width: 100%;
      justify-content: center;
    }

    .btn-ghost {
      width: auto;
    }

    .feature-grid,
    .steps-grid,
    .install-grid,
    .faq-item {
      grid-template-columns: 1fr;
    }

    .closing-card {
      padding: 28px;
      grid-template-columns: 1fr;
    }

    .closing-actions {
      flex-direction: column;
    }

    footer {
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
    }

    .section {
      padding: 72px 0;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .feature-card,
    .install-card,
    .step {
      animation: rise 560ms var(--ease) both;
    }

    .feature-card:nth-child(2),
    .install-card:nth-child(2),
    .step:nth-child(2) { animation-delay: 60ms; }

    .feature-card:nth-child(3),
    .install-card:nth-child(3),
    .step:nth-child(3) { animation-delay: 120ms; }

    .feature-card:nth-child(4) { animation-delay: 80ms; }
    .feature-card:nth-child(5) { animation-delay: 140ms; }
    .feature-card:nth-child(6) { animation-delay: 200ms; }
  }

  @keyframes rise {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: none; }
  }
</style>
</head>
